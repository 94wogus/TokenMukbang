# Swift / SPM
.build/
.swiftpm/
Package.resolved

# Xcode (project is generated by XcodeGen from App/project.yml — do not commit the generated .xcodeproj)
App/*.xcodeproj/
DerivedData/
build/
*.xcuserstate
xcuserdata/

# Ralph Loop run artifacts + local-only scratch files (never commit)
.ralph/
.claude/worktrees/
*.local.md

# Cached usage payloads (may embed account data; never commit)
*.usage-cache.json
cache/

# Browser/MCP tooling artifacts (mockup screenshots land here transiently)
.playwright-mcp/

# E2E visual-verification renders (tools/snapshot.sh output — regenerate, never commit)
.snapshots/

# macOS
.DS_Store
